# Root-level shared defaults (optional)
# Frontend can call its local Next API route by default.
NEXT_PUBLIC_DAILY_BRIEF_URL=/api/daily-brief

# Backend Python binary override used by frontend route when spawning scripts.
PYTHON_BIN=python3

# Future LLM provider keys (currently unused in this repo).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENCLAW_API_KEY=
